# Copy this file to `.env` (which is git-ignored) and fill in your values.

# --- Required for live investigations: Gemini API key (provider: google_genai) ---
# GEMINI_API_KEY is mapped to GOOGLE_API_KEY automatically by the CLI and worker.
GEMINI_API_KEY=your-gemini-api-key-here

# --- Optional: explicit path to the workspaces/ directory ---
# If unset, Biggy uses the in-repo default (the repo's workspaces/ dir). Set this if you run
# from outside the repo or keep the data elsewhere. The CLI does NOT search parent directories.
# BIGGY_WORKSPACES_ROOT=/absolute/path/to/biggy/workspaces

# --- Phase 2 web app infra (defaults match docker-compose.yml host port mappings) ---
# Postgres = the durable system of record (jobs, audit, history). Redis = motion (queue + live trace).
DATABASE_URL=postgres://biggy:biggy@localhost:5433/biggy
REDIS_URL=redis://localhost:6380

# --- Optional: keyless demo mode ---
# When set, the worker replays a canonical Scenario-A investigation — reconstructed in code over the
# real vault + real citation verifier, no Gemini call — as timed trace events, so the full web
# pipeline runs without an API key.
# BIGGY_FAKE_RUN=1

# Absolute path the web's /api/source + /api/topology read from. Defaults to the in-repo workspaces/.
# WORKSPACES_ROOT=/absolute/path/to/biggy/workspaces
